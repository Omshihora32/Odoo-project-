# VendorBridge Environment Variables

# Database
DATABASE_URL=postgresql://vendorbridge:vendorbridge_secret@localhost:5432/vendorbridge

# JWT
JWT_SECRET=vendorbridge-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vendorbridge.com

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
